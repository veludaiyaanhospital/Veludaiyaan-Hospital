# Root-level GitHub ignores

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node artifacts (any nested app)
**/node_modules/
**/.next/
**/out/
**/dist/

# Env files
**/.env
**/.env.local
**/.env.*.local

# Temporary
*.tmp
*.temp
